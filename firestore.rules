/**
 * # Firestore Security Rules
 *
 * ## Core Philosophy
 * This ruleset enforces a strict user-ownership model for writing data, but allows
 * for group-based reading of data. A user's access can be disabled by an admin.
 * The admin role has full read/write access to all data for management purposes.
 *
 * ## Data Structure & Security
 * - **Admin Role:** The user 'post@wastelcompany.eu' has special privileges.
 * - **Disabled Users:** A `disabled` flag on a user's profile blocks all their data access.
 * - **Ownership for Writes:** Non-admin users can only create, update, or delete documents they own (`userId`).
 * - **Customer Groups for Reads:** Non-admin users can read a list of companies that share their `customerId`.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(docData) {
      return isSignedIn() && "userId" in docData && request.auth.uid == docData.userId;
    }
    
    function isCreatingAsOwner() {
      return isSignedIn() && request.auth.uid == request.resource.data.userId;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'post@wastelcompany.eu';
    }

    function isNotDisabled(uid) {
      let userProfile = get(/databases/$(database)/documents/users/$(uid));
      return userProfile.data.disabled == false;
    }
    
    function getUserCustomerId(uid) {
        return get(/databases/$(database)/documents/users/$(uid)).data.customerId;
    }

    // ------------------------------------------------------------------------
    // Collection Rules
    // ------------------------------------------------------------------------
    
    /**
     * @description Manages user profile documents.
     */
    match /users/{userId} {
      // Admin has full read/write access.
      allow read, write: if isAdmin();
      
      // A user can create their own profile upon registration.
      allow create: if request.auth.uid == userId;
      
      // An authenticated user can read their own profile.
      allow read: if isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Manages company documents and their subcollections.
     */
    match /companies/{companyId} {
      // ADMIN ACCESS: Full control for the admin. This rule must be first to ensure it's evaluated.
      allow read, write: if isAdmin();
      
      // --- REGULAR USER ACCESS ---
      
      // Users can query for companies that match their own customerId. This is the only allowed list operation for non-admins.
      allow list: if !isAdmin() && isSignedIn() && isNotDisabled(request.auth.uid) &&
                     request.query.where.customerId == getUserCustomerId(request.auth.uid);
                     
      // Users can read a single company document if it matches their customerId.
      allow get: if !isAdmin() && isSignedIn() && isNotDisabled(request.auth.uid) && 
                    resource.data.customerId == getUserCustomerId(request.auth.uid);

      // Create/Update/Delete rules remain based on ownership for non-admins.
      allow create: if !isAdmin() && isSignedIn() && isCreatingAsOwner() && isNotDisabled(request.auth.uid);
                       
      allow update: if !isAdmin() && isSignedIn() && isOwner(resource.data) && isNotDisabled(request.auth.uid) && request.resource.data.userId == resource.data.userId;

      allow delete: if !isAdmin() && isSignedIn() && isOwner(resource.data) && isNotDisabled(request.auth.uid);

      /**
       * @description Manages the substance inventory for a specific company.
       */
      match /inventory/{substanceId} {
        // Grant access if user is admin OR has read access to the parent company.
        allow read, write: if isAdmin() || (
                              !isAdmin() && isSignedIn() && isNotDisabled(request.auth.uid) && 
                              get(/databases/$(database)/documents/companies/$(companyId)).data.customerId == getUserCustomerId(request.auth.uid)
                            );
      }
    }
  }
}
