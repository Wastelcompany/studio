
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return isSignedIn() && (
        request.auth.token.email == 'post@wastelcompany.eu' ||
        (exists(userPath) && get(userPath).data.role == 'admin')
      );
    }

    function isNotDisabled(uid) {
      let userPath = /databases/$(database)/documents/users/$(uid);
      return !exists(userPath) || get(userPath).data.disabled == false;
    }
    
    function getUserCustomerId(uid) {
        let userPath = /databases/$(database)/documents/users/$(uid);
        return exists(userPath) ? get(userPath).data.customerId : null;
    }

    match /users/{userId} {
      allow read, write: if isAdmin();
      allow create: if request.auth.uid == userId;
      allow read: if isSignedIn() && request.auth.uid == userId;
    }

    match /customers/{customerId} {
      allow read, write: if isAdmin();
      allow get: if isSignedIn() && getUserCustomerId(request.auth.uid) == customerId;
    }

    match /companies/{companyId} {
      allow read, write: if isAdmin();
      allow list: if isSignedIn() && isNotDisabled(request.auth.uid);
      allow get: if isSignedIn() && isNotDisabled(request.auth.uid) && 
                    resource.data.customerId == getUserCustomerId(request.auth.uid);

      allow create: if isSignedIn() && isNotDisabled(request.auth.uid);
      allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.userId || isAdmin()) && isNotDisabled(request.auth.uid);

      match /inventory/{substanceId} {
        allow read, write: if isAdmin() ||
                             (
                               isSignedIn() &&
                               isNotDisabled(request.auth.uid) &&
                               get(/databases/$(database)/documents/companies/$(companyId)).data.customerId ==
                               getUserCustomerId(request.auth.uid)
                             );
        
        match /history/{logId} {
          allow read, write: if isAdmin() ||
                               (
                                 isSignedIn() &&
                                 isNotDisabled(request.auth.uid) &&
                                 get(/databases/$(database)/documents/companies/$(companyId)).data.customerId ==
                                 getUserCustomerId(request.auth.uid)
                               );
        }
      }
    }

    match /ai_usage_logs/{logId} {
      allow read, list: if isAdmin();
      allow create: if isSignedIn();
    }
  }
}
