/**
 * # Firestore Security Rules
 *
 * ## Core Philosophy
 * This ruleset enforces a strict user-ownership model where users must have a verified
 * email address to access data. All data is private and accessible only by the verified
 * user who created it.
 *
 * ## Data Structure & Security
 * - **Email Verification:** Access to all data collections (except for creating one's own
 *   user profile upon signup) requires `request.auth.token.email_verified == true`.
 * - **Strict Ownership:** Verified users can only access documents they own, verified
 *   by matching `request.auth.uid` with the `userId` field in the document.
 * - **Query-based Listing:** Listing companies is only permitted for verified users via a
 *   query that explicitly filters by their user ID.
 * - **Subcollection Security:** Access to subcollections like `inventory` is granted by
 *   checking the ownership of the parent company document.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------

    /**
     * Checks if a user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the authenticated user's UID matches the document's `userId` field.
     */
    function isOwner() {
      return isSignedIn() 
             && "userId" in resource.data 
             && request.auth.uid == resource.data.userId;
    }
    
    /**
     * Checks if the user is creating a document for themselves.
     */
    function isCreatingAsOwner() {
        return isSignedIn() && request.auth.uid == request.resource.data.userId;
    }

    // ------------------------------------------------------------------------
    // Collection Rules
    // ------------------------------------------------------------------------
    
    /**
     * @description Manages user profile documents.
     * @path /users/{userId}
     * @allow A user can create their own profile upon registration.
     * @allow An authenticated user can read, update, and delete their own profile.
     * @allow The admin user can list all user profiles.
     */
    match /users/{userId} {
      allow create: if request.auth.uid == userId;
      allow read, update, delete: if isSignedIn() && request.auth.uid == userId;
      allow list: if isSignedIn() && request.auth.token.email == 'post@wastelcompany.eu';
    }

    /**
     * @description Manages company documents, which act as containers for substance inventories.
     * @path /companies/{companyId}
     * @allow An authenticated user can create, read, update, and delete their own company documents.
     */
    match /companies/{companyId} {
      allow read, update, delete: if isOwner();
      allow create: if isCreatingAsOwner();

      /**
       * @description Manages the substance inventory for a specific company.
       * @path /companies/{companyId}/inventory/{substanceId}
       * @allow The company owner can perform any action.
       */
      match /inventory/{substanceId} {
        allow read, write: if isSignedIn() &&
                             exists(/databases/$(database)/documents/companies/$(companyId)) &&
                             get(/databases/$(database)/documents/companies/$(companyId)).data.userId == request.auth.uid;
      }
    }
  }
}
