/**
 * # Firestore Security Rules
 *
 * ## Core Philosophy
 * This ruleset enforces a strict user-ownership model. All data is considered private and is accessible only by the user who created it. There are no public collections or shared data access roles. The rules are designed to be highly secure from an authorization standpoint.
 *
 * ## Data Structure
 * All company data is stored in a top-level `/companies` collection. Each company document contains a `userId` field to signify ownership. This allows for flexible queries while maintaining strict ownership controls. A user's inventory is nested under their company at `/companies/{companyId}/inventory/{substanceId}`.
 *
 * ## Key Security Decisions
 * - **No Public Access:** All read and write operations require the user to be authenticated. There are no publicly readable or writable collections.
 * - **Strict Ownership:** Users can only access documents they own, verified by matching `request.auth.uid` with the `userId` field in the document.
 * - **Query-based Listing:** Listing companies is only permitted via a query that explicitly filters by the authenticated user's ID (e.g., `where('userId', '==', auth.uid)`). This is enforced by the `isOwner` check on read.
 * - **Subcollection Security:** For subcollections like `inventory`, ownership is verified by checking the `userId` on the parent company document using a `get()` call.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------

    /**
     * Checks if a user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the authenticated user's UID matches the document's `userId` field.
     * Used for read, update, and delete operations on existing documents.
     */
    function isOwner() {
      return isSignedIn() && request.auth.uid == resource.data.userId;
    }
    
    /**
     * Checks if the authenticated user's UID matches the `userId` field
     * in the data of the document being created.
     */
    function isCreatingAsOwner() {
        return isSignedIn() && request.auth.uid == request.resource.data.userId;
    }

    /**
     * Checks if the user owns the parent company document for nested resources.
     */
    function isParentCompanyOwner(companyId) {
        return isSignedIn() && get(/databases/$(database)/documents/companies/$(companyId)).data.userId == request.auth.uid;
    }

    // ------------------------------------------------------------------------
    // Collection Rules
    // ------------------------------------------------------------------------

    /**
     * @description Manages company documents, which act as containers for substance inventories.
     * @path /companies/{companyId}
     * @allow A user can create, read, update, and delete their own company documents.
     * @allow A user can list only the companies they own via a client-side query.
     * @deny A user cannot access another user's company in any way.
     */
    match /companies/{companyId} {
      allow read, update, delete: if isOwner();
      allow create: if isCreatingAsOwner();

      /**
       * @description Manages the substance inventory for a specific company.
       * @path /companies/{companyId}/inventory/{substanceId}
       * @allow The company owner can perform any action (read, list, create, update, delete).
       * @deny Anyone other than the company owner is denied all access.
       */
      match /inventory/{substanceId} {
        allow read, write: if isParentCompanyOwner(companyId);
      }
    }
  }
}
