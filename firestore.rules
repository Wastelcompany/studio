/**
 * # Firestore Security Rules
 *
 * ## Core Philosophy
 * This ruleset enforces a strict user-ownership model for writing data, but allows
 * for group-based reading of data. A user's access can be disabled by an admin.
 *
 * ## Data Structure & Security
 * - **Admin Role:** The user 'post@wastelcompany.eu' has special privileges to manage users.
 * - **Disabled Users:** A `disabled` flag on a user's profile blocks all their data access.
 * - **Ownership for Writes:** Users can only create, update, or delete documents they own,
 *   verified by matching `request.auth.uid` with the `userId` field in a document.
 * - **Customer Groups for Reads:** Users can read a list of companies that share their `customerId`.
 *   They can also read individual company documents if they belong to the same customer group.
 * - **Query-based Listing:** Listing companies is only permitted via a query that filters
 *   by the user's `customerId`, ensuring they only get data from their group. Admins have unrestricted list access.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(doc) {
      return isSignedIn() && "userId" in doc && request.auth.uid == doc.userId;
    }
    
    function isCreatingAsOwner() {
      return isSignedIn() && request.auth.uid == request.resource.data.userId;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'post@wastelcompany.eu';
    }

    function isNotDisabled(uid) {
      let userProfile = get(/databases/$(database)/documents/users/$(uid));
      return userProfile.data.disabled == false;
    }

    function isMemberOfSameCustomerGroup(company) {
      let requestUserProfile = get(/databases/$(database)/documents/users/$(request.auth.uid));
      // User must have a customerId to be in a group.
      if (!('customerId' in requestUserProfile.data) || requestUserProfile.data.customerId == null) {
        return false;
      }
      // Company must have a customerId.
      if (!('customerId' in company) || company.customerId == null) {
        return false;
      }
      return requestUserProfile.data.customerId == company.customerId;
    }

    // ------------------------------------------------------------------------
    // Collection Rules
    // ------------------------------------------------------------------------
    
    /**
     * @description Manages user profile documents.
     * @allow A user can create their own profile upon registration.
     * @allow An authenticated user can read their own profile.
     * @allow Admin can read all profiles and write to any profile to manage them.
     */
    match /users/{userId} {
      allow create: if request.auth.uid == userId;
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow list, write: if isAdmin();
    }

    /**
     * @description Manages company documents.
     * @allow Create if user is creating for themselves, is not disabled, and sets customerId correctly.
     * @allow Read if user is not disabled and is a member of the company's customer group, OR if user is admin.
     * @allow Update if user is the owner and is not disabled, OR if user is admin. The userId must not change.
     * @allow Delete if user is the owner and is not disabled, OR if user is admin.
     * @allow List if user is signed in. Results are filtered by the read rule.
     */
    match /companies/{companyId} {
      allow create: if isCreatingAsOwner() && 
                       isNotDisabled(request.auth.uid) &&
                       request.resource.data.customerId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.customerId;
                       
      allow read: if isAdmin() || (isNotDisabled(request.auth.uid) && isMemberOfSameCustomerGroup(resource.data));

      allow update: if isAdmin() || (
                       isOwner(resource.data) && 
                       isNotDisabled(request.auth.uid) &&
                       request.resource.data.userId == resource.data.userId
                     );

      allow delete: if isAdmin() || (isOwner(resource.data) && isNotDisabled(request.auth.uid));

      allow list: if isSignedIn();

      /**
       * @description Manages the substance inventory for a specific company.
       * @allow Access is granted if the user has read access to the parent company or is an admin.
       */
      match /inventory/{substanceId} {
        allow read, write: if isAdmin() || (isNotDisabled(request.auth.uid) && 
                             isMemberOfSameCustomerGroup(get(/databases/$(database)/documents/companies/$(companyId)).data));
      }
    }
  }
}
