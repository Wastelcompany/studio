
/**
 * # Firestore Security Rules
 *
 * ## Core Philosophy
 * This ruleset enforces a strict user-ownership model for writing data, but allows
 * for group-based reading of data. A user's access can be disabled by an admin.
 * The admin role has full read/write access to all data for management purposes.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Robust admin check based on the dedicated admin email
      return isSignedIn() && request.auth.token.email == 'post@wastelcompany.eu';
    }

    function isNotDisabled(uid) {
      // Check if user document exists and if disabled is false
      let userPath = /databases/$(database)/documents/users/$(uid);
      return !exists(userPath) || get(userPath).data.disabled == false;
    }
    
    function getUserCustomerId(uid) {
        let userPath = /databases/$(database)/documents/users/$(uid);
        return exists(userPath) ? get(userPath).data.customerId : null;
    }

    // ------------------------------------------------------------------------
    // Collection Rules
    // ------------------------------------------------------------------------
    
    match /users/{userId} {
      allow read, write: if isAdmin();
      allow create: if request.auth.uid == userId;
      allow read: if isSignedIn() && request.auth.uid == userId;
    }

    match /customers/{customerId} {
      allow read, write: if isAdmin();
      allow get: if isSignedIn() && getUserCustomerId(request.auth.uid) == customerId;
    }

    match /companies/{companyId} {
      allow read, write: if isAdmin();
      allow list: if isSignedIn() && isNotDisabled(request.auth.uid);
      allow get: if isSignedIn() && isNotDisabled(request.auth.uid) && 
                    resource.data.customerId == getUserCustomerId(request.auth.uid);

      allow create: if isSignedIn() && isNotDisabled(request.auth.uid);
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.userId && isNotDisabled(request.auth.uid);

      match /inventory/{substanceId} {
        allow read, write: if isAdmin() ||
                             (
                               isSignedIn() &&
                               isNotDisabled(request.auth.uid) &&
                               get(/databases/$(database)/documents/companies/$(companyId)).data.customerId ==
                               getUserCustomerId(request.auth.uid)
                             );
      }
    }

    match /ai_usage_logs/{logId} {
      // Admin can list and read logs for the dashboard
      allow read, list: if isAdmin();
      // Any signed in user can create a log entry when using AI features
      allow create: if isSignedIn();
    }
  }
}
