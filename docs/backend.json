
{
  "entities": {
    "Customer": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Customer",
      "type": "object",
      "description": "Represents the legal billing entity (the client). A customer can have multiple facilities/companies.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Customer."
        },
        "name": {
          "type": "string",
          "description": "Official legal name of the customer for invoicing."
        },
        "address": {
          "type": "string",
          "description": "Registered business address for invoicing."
        },
        "kvkNumber": {
          "type": "string",
          "description": "Chamber of Commerce (KVK) registration number."
        },
        "billingEmail": {
          "type": "string",
          "format": "email",
          "description": "Email address where invoices should be sent."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "name"
      ]
    },
    "Company": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Company",
      "type": "object",
      "description": "Represents a physical facility or branch belonging to a Customer.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Company entity."
        },
        "userId": {
          "type": "string",
          "description": "Reference to the User who is the primary operator of this facility."
        },
        "customerId": {
          "type": "string",
          "description": "Identifier for the Customer (billing entity) this facility belongs to."
        },
        "name": {
          "type": "string",
          "description": "A user-defined name for the facility."
        },
        "address": {
          "type": "string",
          "description": "The physical location of the facility."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp when the company was created.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "userId",
        "name",
        "customerId"
      ]
    },
    "SubstanceInventoryItem": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SubstanceInventoryItem",
      "type": "object",
      "description": "Represents a single chemical substance present in a specific company's inventory.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the substance."
        },
        "productName": {
          "type": "string",
          "description": "The name of the product or substance."
        },
        "casNumber": {
          "type": "string",
          "description": "The Chemical Abstracts Service (CAS) number."
        },
        "hStatements": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Array of Hazard statements (H-statements)."
        },
        "sevesoCategoryIds": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Array of Seveso category IDs the substance falls into."
        },
        "arieCategoryIds": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Array of ARIE category IDs the substance falls into."
        },
        "isNamedSubstance": {
          "type": "boolean",
          "description": "Flag indicating if it is a named substance."
        },
        "namedSubstanceName": {
          "type": "string",
          "description": "The name of the substance if it's a named one."
        },
        "quantity": {
          "type": "number",
          "description": "The quantity of the substance present, in tons."
        },
        "sdsUri": {
          "type": "string",
          "description": "Base64 data URI of the original SDS document."
        }
      },
      "required": [
        "id",
        "productName",
        "hStatements",
        "sevesoCategoryIds",
        "arieCategoryIds",
        "isNamedSubstance",
        "quantity"
      ]
    },
    "QuantityLog": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "QuantityLog",
      "type": "object",
      "description": "Represents a daily snapshot of the substance quantity.",
      "properties": {
        "date": { "type": "string", "description": "Date of the log in YYYY-MM-DD format." },
        "quantity": { "type": "number", "description": "The recorded quantity in tons." },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["date", "quantity", "updatedAt"]
    },
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User Profile",
      "type": "object",
      "description": "Represents a user's profile information.",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's unique ID from Firebase Authentication."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the user profile was created."
        },
        "customerId": {
          "type": "string",
          "description": "Identifier for grouping users into a single customer account."
        },
        "customerName": {
          "type": "string",
          "description": "Display name for the customer group."
        },
        "disabled": {
          "type": "boolean",
          "description": "Flag to disable user account."
        },
        "role": {
          "type": "string",
          "enum": ["admin", "user"]
        }
      },
      "required": [
        "uid",
        "email",
        "createdAt",
        "customerId",
        "customerName",
        "disabled"
      ]
    },
    "AiUsageLog": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AI Usage Log",
      "type": "object",
      "description": "Tracks AI model usage for billing and analytics.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["SDS_EXTRACTION", "KVK_SEARCH"] },
        "model": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "estimatedCost": { "type": "number", "description": "Estimated cost in USD." }
      },
      "required": ["id", "userId", "type", "timestamp"]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "Stores public profile information for each user."
        }
      },
      {
        "path": "/customers/{customerId}",
        "definition": {
          "entityName": "Customer",
          "schema": {
            "$ref": "#/backend/entities/Customer"
          },
          "description": "Stores legal customer (billing) information."
        }
      },
      {
        "path": "/companies/{companyId}",
        "definition": {
          "entityName": "Company",
          "schema": {
            "$ref": "#/backend/entities/Company"
          },
          "description": "Stores facility/branch information linked to a customer."
        }
      },
      {
        "path": "/companies/{companyId}/inventory/{substanceId}",
        "definition": {
          "entityName": "SubstanceInventoryItem",
          "schema": {
            "$ref": "#/backend/entities/SubstanceInventoryItem"
          },
          "description": "Contains chemical substances belonging to a specific company facility."
        }
      },
      {
        "path": "/companies/{companyId}/inventory/{substanceId}/history/{logId}",
        "definition": {
          "entityName": "QuantityLog",
          "schema": {
            "$ref": "#/backend/entities/QuantityLog"
          },
          "description": "Historical log of substance quantity."
        }
      },
      {
        "path": "/ai_usage_logs/{logId}",
        "definition": {
          "entityName": "AiUsageLog",
          "schema": {
            "$ref": "#/backend/entities/AiUsageLog"
          },
          "description": "Logs of AI model usage."
        }
      }
    ],
    "reasoning": "The structure tracks historical quantity changes daily and includes AI usage tracking."
  }
}
